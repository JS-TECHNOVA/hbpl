# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Django core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-super-secret-key-here
DEBUG=True

# Comma-separated list of allowed hosts (production example below)
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
# Leave unset (or empty) to use SQLite locally.
# Set to a postgres:// URL for production:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL=

# Set to True to enforce SSL on the Postgres connection (recommended in prod)
DB_SSL=False

# ── CORS / CSRF ───────────────────────────────────────────────────────────────
# Comma-separated extra origins allowed by CORS in production (your frontend URL).
# CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Comma-separated origins Django will accept CSRF tokens from (Django 4+ requirement).
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# ── HTTPS / Security headers ──────────────────────────────────────────────────
# Set to True when deployed behind HTTPS. Enables SSL redirect, secure cookies,
# and the X-Forwarded-Proto proxy header.
HTTPS_ENABLED=False

# HSTS — ramp up gradually once HTTPS is confirmed stable:
#   Step 1: 3600  (1 hour)  — test
#   Step 2: 86400  (1 day)  — monitor
#   Step 3: 31536000 (1 year) + subdomains + preload — final
HSTS_SECONDS=0
HSTS_INCLUDE_SUBDOMAINS=False
HSTS_PRELOAD=False

# Referrer-Policy header (same-origin | strict-origin | no-referrer | ...)
SECURE_REFERRER_POLICY=same-origin

# Clickjacking protection: DENY | SAMEORIGIN
X_FRAME_OPTIONS=DENY

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Leave EMAIL_HOST_USER unset to print emails to console in development.
# In production fill in your Gmail address + an App Password:
#   Google Account → Security → 2-Step Verification → App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=yourname@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=HBPL <yourname@gmail.com>

# ── Media / Storage ───────────────────────────────────────────────────────────
# (Add S3/GCS keys here if you move media off-disk in production)
